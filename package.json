{
  "name": "logapp",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.amornrin.myapp",
    "win": {
      "target": "nsis", 
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Data707 Login System"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3"
  }
}
